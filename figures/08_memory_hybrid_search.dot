digraph G {
  graph [bgcolor="#FCFDFE", pad="0.25", nodesep="0.45", ranksep="0.65", splines=ortho, fontname="Noto Sans CJK SC", fontsize=22, labelloc=t, labeljust=l, label="08. 跨会话记忆：存储、索引、混合检索与 Dream 整合"];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=13, color="#CBD5E1", penwidth=1.2, margin="0.16,0.10", fillcolor="#FFFFFF", fontcolor="#172033"];
  edge [fontname="Noto Sans CJK SC", fontsize=11, color="#64748B", penwidth=1.35, arrowsize=0.75, fontcolor="#475569"];

  subgraph cluster_storage {
    label="Markdown 持久层"; color="#A7D7C5"; style="rounded,filled"; fillcolor="#F3FBF7";
    global [label="全局 MEMORY.md\n~/.grok/memory/", fillcolor="#E7F7EF"];
    workspace [label="工作区 MEMORY.md\n{repo-slug}-{hash8}/", fillcolor="#E7F7EF"];
    sessions [label="Session Logs\nsessions/YYYY-MM-DD-...md", fillcolor="#E7F7EF"];
    security [label="安全边界\ncanonicalize + starts_with\n阻止目录逃逸", shape=note, fillcolor="#FFF8E8", color="#F2C66D"];
  }
  subgraph cluster_index {
    label="索引与向量化"; color="#8EB8F8"; style="rounded,filled"; fillcolor="#F4F8FF";
    watch [label="Watcher / Session-End 写入\n检测 Markdown 变化", fillcolor="#EAF2FF"];
    chunk [label="Chunker\n按 Markdown 标题切块\n保留 path + line range", fillcolor="#EAF2FF"];
    sqlite [label="MemoryIndex (SQLite)\nchunks + FTS5 BM25\naccess_count / created_at", fillcolor="#EAF2FF"];
    embed [label="EmbeddingProvider\n批量 32 条向量化", fillcolor="#EAF2FF"];
    vec [label="sqlite-vec KNN\n可用时启用", fillcolor="#EAF2FF"];
  }
  subgraph cluster_search {
    label="Hybrid Search 排序管线"; color="#C9B5F4"; style="rounded,filled"; fillcolor="#FAF7FF";
    query [label="用户查询 / Query Expansion", fillcolor="#F0EAFE"];
    fts [label="FTS5 候选\n含 evergreen 补充查询", fillcolor="#F0EAFE"];
    knn [label="向量候选\nQuery embedding → KNN", fillcolor="#F0EAFE"];
    merge [label="按 chunk_id 合并\n归一化 FTS / L2 similarity", fillcolor="#F0EAFE"];
    rank [label="时间衰减 + 来源权重\n访问频率 boost + min_score", fillcolor="#F0EAFE"];
    mmr [label="MMR 去冗余重排\n限制 max_results", fillcolor="#F0EAFE"];
    inject [label="注入会话上下文\n记录 access_count", fillcolor="#F0EAFE"];
  }
  subgraph cluster_dream {
    label="Dream / 长期记忆整合"; color="#F1C58B"; style="rounded,filled"; fillcolor="#FFF9F1";
    consolidate [label="会话结束整合\n从 session logs 提炼", fillcolor="#FFF0D8"];
    curate [label="写入 Global / Workspace MEMORY.md\n人工可编辑、再次索引", fillcolor="#FFF0D8"];
  }
  global -> watch; workspace -> watch; sessions -> watch;
  watch -> chunk -> sqlite;
  sqlite -> embed -> vec;
  query -> fts; query -> knn;
  sqlite -> fts; vec -> knn;
  fts -> merge; knn -> merge;
  merge -> rank -> mmr -> inject;
  sessions -> consolidate -> curate;
  curate -> global; curate -> workspace;
  security -> global [style=dashed, arrowhead=none]; security -> workspace [style=dashed, arrowhead=none];
  degrade [label="优雅降级：无 sqlite-vec / embedding 时退化为 FTS-only；临时目录工作区跳过持久写入。", shape=note, fillcolor="#F8FAFC", color="#CBD5E1"];
  vec -> degrade [style=dashed, arrowhead=none];

}