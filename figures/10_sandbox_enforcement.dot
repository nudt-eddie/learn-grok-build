digraph G {
  graph [bgcolor="#FCFDFE", pad="0.25", nodesep="0.45", ranksep="0.65", splines=ortho, fontname="Noto Sans CJK SC", fontsize=22, labelloc=t, labeljust=l, label="10. Sandbox：Profile、bwrap、内核能力与子进程网络隔离"];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=13, color="#CBD5E1", penwidth=1.2, margin="0.16,0.10", fillcolor="#FFFFFF", fontcolor="#172033"];
  edge [fontname="Noto Sans CJK SC", fontsize=11, color="#64748B", penwidth=1.35, arrowsize=0.75, fontcolor="#475569"];

  start [label="进程启动\n解析 sandbox profile", fillcolor="#EAF2FF"];
  subgraph cluster_profile {
    label="Profile 解析"; color="#8EB8F8"; style="rounded,filled"; fillcolor="#F4F8FF";
    config [label="内置 / Custom Profile\nworkspace + sandbox.toml", fillcolor="#EAF2FF"];
    resolve [label="resolve_profile\ncapability set + deny paths\nrestrict_network", fillcolor="#EAF2FF"];
    guard [label="读拒绝需求判定\n配置本征判断，避免解析失败时静默降级", fillcolor="#FFE9E9", color="#F2A6A6"];
  }
  subgraph cluster_linux {
    label="Linux 预启动 Mount Namespace"; color="#A7D7C5"; style="rounded,filled"; fillcolor="#F3FBF7";
    plan [label="BwrapDenyPlan\ndeny_write / deny_read / globs", fillcolor="#E7F7EF"];
    bwrap [label="bwrap re-exec\nro-bind 写拒绝路径\n000 placeholder 覆盖读拒绝路径", fillcolor="#E7F7EF"];
    seccomp [label="子进程网络过滤\n已知 Linux launch path 安装 seccomp", fillcolor="#E7F7EF"];
  }
  subgraph cluster_kernel {
    label="进程级内核沙箱（nono）"; color="#C9B5F4"; style="rounded,filled"; fillcolor="#FAF7FF";
    apply [label="Sandbox::apply(capabilities)\nLandlock / Seatbelt\n不可逆", fillcolor="#F0EAFE"];
    install [label="全局 SandboxState\nprofile / logger / metrics\nchild network flag", fillcolor="#F0EAFE"];
  }
  tools [label="Agent 工具与 tokio::fs\n子进程 Bash / PTY", fillcolor="#FFF0D8", color="#F1C58B"];
  violation [label="SandboxLogger\n违规事件立即 flush\nmetrics / diagnostics", fillcolor="#FFE9E9", color="#F2A6A6"];
  degrade [label="平台不支持时：记录 apply_failed 并继续；\n但需要 read-deny / glob 超限的启动路径采用 fail-closed。", shape=note, fillcolor="#FFF8E8", color="#F2C66D"];
  start -> config -> resolve;
  resolve -> guard;
  resolve -> plan [label="Linux"];
  plan -> bwrap -> apply;
  resolve -> apply [label="macOS / 已在 bwrap"];
  apply -> install -> tools;
  install -> seccomp -> tools;
  tools -> violation [label="越权访问"];
  guard -> degrade [style=dashed, arrowhead=none];
  apply -> degrade [style=dashed, arrowhead=none];
  note [label="边界设计：LLM API 所需网络保留在主进程；工具子进程网络按 profile 单独限制。", shape=note, fillcolor="#F8FAFC", color="#CBD5E1"];
  seccomp -> note [style=dashed, arrowhead=none];

}